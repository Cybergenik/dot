#!/bin/bash

SCREEN=rv

SAVE_PATH=$HOME/media/vids/

LAST_FILE=$SAVE_PATH.last

mkdir -p "$SAVE_PATH"

# SAVE ARGS
ARGC=$#
ARGV=$@

while [ ! $# -eq 0 ]
do
	case "$1" in
		--name | -n)
			FILE=$SAVE_PATH$2.mp4
			;;
	esac
	shift
done

if [ -z "$FILE" ]
then
	FILE=$(date +$SAVE_PATH%Y%m%d-%H%M%S.mp4)
fi


# RESTORE ARGS
set -- $ARGV

while [ ! $# -eq 0 ]
do
	case "$1" in
		--copy | -c)
			nohup bash -c 'cat '$LAST_FILE' | xclip &' > /dev/null 2>&1
			exit 0
			;;
		--last | -l)
			cat $LAST_FILE && echo
			exit 0
			;;
		--view | -v)
			if [ -z "$2" ]
			then
				nohup mplayer $(cat $LAST_FILE) > /dev/null 2>&1 &
			else
				nohup mplayer $SAVE_PATH$2.mp4 > /dev/null 2>&1 &
			fi
			exit 0
			;;
	esac
	shift
done

# RESTORE ARGS
set -- $ARGV

PS=$(pgrep -f "SCREEN -dmS $SCREEN")

if [ ! -z "$PS" ]
then
	sleep .2
	screen -S $SCREEN -p 0 -X stuff "q"
else
	screen -dmS $SCREEN
	sleep .2
	screen -S $SCREEN -p 0 -X stuff "rvid $FILE; exit^M"

	nohup bash -c 'echo -n '$FILE' > '$LAST_FILE > /dev/null 2>&1

	echo "recording!"
	exit 0
fi

while [ ! $# -eq 0 ]
do
	case "$1" in
		--rename | -r)
			result=$(mktemp)
			prevloc=$(mktemp)
			ROFI_SAVE_DIR="$SAVE_PATH" ROFI_SAVE_EXT=.mp4 ROFI_SAVE_RESULT="$result" ROFI_SAVE_PREVLOC="$prevloc" rofi -show save -modi "save:rofi-save" >/dev/null 2>&1
			new=$(cat "$result")
			rm -f "$result" "$prevloc"
			old=$(cat "$LAST_FILE")
			if [ -n "$new" ] && [ "$new" != "$old" ]; then
				if [ -e "$new" ]; then
					confirm=$(echo -e "Y\nn" | rofi -dmenu -p "overwrite $(basename "$new")? [Y/n]" 2>/dev/null)
					[ "$confirm" = "n" ] && new=""
				fi
				if [ -n "$new" ]; then
					mkdir -p "$(dirname "$new")"
					mv "$old" "$new"
					echo -n "$new" > "$LAST_FILE"
				fi
			fi
			xclip >&- 2>&- < "$LAST_FILE"
			cat "$LAST_FILE"
			;;
		--echo | -e)
			cat $LAST_FILE
			;;
		--xclip | -x)
			nohup bash -c 'cat '$LAST_FILE' | xclip &' > /dev/null 2>&1
			;;
		--play | -p)
			nohup mplayer $(cat $LAST_FILE) > /dev/null 2>&1 &
			;;
	esac
	shift
done
